# Resend API key — get yours at https://resend.com
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxx

# Cloudflare Zone ID — find in: Dashboard → ibazaldua.com → Overview → API Zone ID
CLOUDFLARE_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare API token — create at: My Profile → API Tokens → Create Custom Token
# Required permissions: Zone → DNS → Edit
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
