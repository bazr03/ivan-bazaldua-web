---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CtaBanner from "../components/CtaBanner.astro";

const education = [
  {
    degree: "Maestría en Ciencias en Geofísica Aplicada",
    school:
      "CICESE — Centro de Investigación Científica y de Educación Superior de Ensenada",
  },
  {
    degree: "Ingeniero Geofísico",
    school: "Universidad Autónoma de Nuevo León (UANL)",
  },
];

const skills = [
  { group: "Métodos eléctricos", items: "TRE · Potencial Inducido (IP) · Resistividad de suelos" },
  { group: "Métodos sísmicos", items: "Tomografía de Refracción Sísmica (TRS) · MASW" },
  { group: "Electromagnético", items: "Georradar (GPR)" },
  { group: "Procesamiento e interpretación", items: "Res2DInv · ZondST2D · SeisImager · EasyMASW · ResIPy · Surfer · QGIS · AutoCAD" },
];
---

<Layout
  title="Sobre mí — Iván Bazaldúa, M.C. Geofísica Aplicada"
  description="Ingeniero Geofísico (UANL) y Maestro en Ciencias en Geofísica Aplicada (CICESE), especializado en estudios del subsuelo con métodos no invasivos."
>
  <section class="section--soft page-head">
    <div class="container">
      <p class="eyebrow">Sobre mí</p>
      <h1>Sobre mí</h1>
    </div>
  </section>

  <section class="section">
    <div class="container intro">
      <div class="intro__photo">
        <img src="/img/ICBR_2.png" alt="Iván Bazaldúa" width="260" height="260" />
      </div>
      <div class="intro__text">
        <p>
          Soy <strong>Iván Bazaldúa</strong>, Ingeniero Geofísico y Maestro en
          Ciencias en Geofísica Aplicada. Me especializo en estudios del
          subsuelo con métodos geofísicos no invasivos, ayudando a profesionales
          y empresas de obra civil, minería y recursos hídricos a tomar
          decisiones respaldadas en datos confiables.
        </p>
        <p>
          Mi trabajo combina el rigor científico de la geofísica con un enfoque
          práctico: no entrego solo mediciones, entrego interpretaciones claras
          y recomendaciones aplicables a tu proyecto.
        </p>
        <Button href="/img/ICBR_CV_2025.pdf" variant="secondary">
          Descargar CV
        </Button>
      </div>
    </div>
  </section>

  <hr class="wave-divider" />

  <section class="section section--soft">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Formación</p>
        <h2>Respaldo académico</h2>
        <ul class="education">
          {
            education.map((e) => (
              <li class="education__item">
                <h3>{e.degree}</h3>
                <p>{e.school}</p>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <p class="eyebrow">Especialidades técnicas</p>
        <h2>Métodos y herramientas</h2>
        <ul class="skills">
          {
            skills.map((s) => (
              <li class="skills__item">
                <h3>{s.group}</h3>
                <p>{s.items}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <CtaBanner
    heading="¿Quieres saber si tu proyecto es viable con estudios geofísicos?"
  />
</Layout>

<style>
  .page-head {
    padding-block: var(--space-24) var(--space-16);
  }
  .intro {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .intro__photo {
    display: flex;
    justify-content: center;
  }
  .intro__photo img {
    width: 260px;
    height: 260px;
    object-fit: cover;
    border-radius: var(--radius-full);
    border: 6px solid var(--color-electric);
    box-shadow: var(--shadow-md);
  }
  .intro__text p {
    margin-bottom: var(--space-4);
    font-size: 1.0625rem;
  }
  .intro__text :global(.btn) {
    margin-top: var(--space-2);
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
  }
  .two-col h2 {
    margin-top: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .education__item,
  .skills__item {
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-grey-light);
  }
  .education__item h3 {
    font-size: 1.125rem;
  }
  .education__item p,
  .skills__item p {
    color: var(--text-secondary);
    margin-top: var(--space-1);
  }
  .skills__item h3 {
    font-size: 1rem;
    color: var(--color-electric-dark);
  }
  @media (max-width: 860px) {
    .intro,
    .two-col {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .intro__photo {
      order: -1;
    }
  }
</style>
