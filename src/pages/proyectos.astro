---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CtaBanner from "../components/CtaBanner.astro";

// Published projects only (draft: false), ordered.
const projects = (await getCollection("proyectos", ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const hasProjects = projects.length > 0;
---

<Layout
  title="Proyectos — Estudios geofísicos | Iván Bazaldúa"
  description="Casos de estudio de estudios geofísicos en obra civil, minería y agua subterránea: problema, método aplicado y resultado."
>
  <section class="section--soft page-head">
    <div class="container">
      <p class="eyebrow">Proyectos</p>
      <h1>Proyectos</h1>
      <p class="page-head__lead">
        Estudios geofísicos realizados en campo para resolver problemas reales
        de obra civil, minería y agua subterránea.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {
        hasProjects ? (
          <div class="project-grid">
            {projects.map((p) => (
              <article class="project">
                {p.data.image && (
                  <div class="project__media">
                    <img src={p.data.image.src} alt={p.data.title} loading="lazy" />
                  </div>
                )}
                <div class="project__body">
                  <span class="project__sector">{p.data.sector}</span>
                  <h2 class="project__title">{p.data.title}</h2>
                  <dl>
                    <div><dt>Ubicación</dt><dd>{p.data.location}</dd></div>
                    <div><dt>Método</dt><dd>{p.data.method}</dd></div>
                    <div><dt>Objetivo</dt><dd>{p.data.objective}</dd></div>
                    <div><dt>Resultado</dt><dd>{p.data.result}</dd></div>
                  </dl>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="placeholder">
            <h2>Portafolio en preparación</h2>
            <p>
              Estoy documentando una selección de estudios representativos.
              Mientras tanto, si quieres conocer casos similares al tuyo,
              escríbeme y con gusto te comparto ejemplos relevantes.
            </p>
            <Button href="/contacto" variant="primary">Contáctame</Button>
          </div>
        )
      }
    </div>
  </section>

  {hasProjects && <CtaBanner heading="¿Tu proyecto se parece a alguno de estos?" />}
</Layout>

<style>
  .page-head {
    padding-block: var(--space-24) var(--space-16);
  }
  .page-head__lead {
    max-width: 60ch;
    margin-top: var(--space-4);
    font-size: 1.125rem;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-8);
  }
  .project {
    border: 1px solid var(--color-grey-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    background: var(--color-white);
  }
  .project__media img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .project__body {
    padding: var(--space-6);
  }
  .project__sector {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-electric-dark);
    margin-bottom: var(--space-2);
  }
  .project__title {
    font-size: 1.5rem;
    margin-bottom: var(--space-4);
  }
  .project dl div {
    padding-block: var(--space-2);
    border-top: 1px solid var(--color-grey-light);
  }
  .project dt {
    font-family: var(--font-heading);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
  }
  .project dd {
    margin-top: var(--space-1);
  }
  .placeholder {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    padding: var(--space-16) var(--space-6);
    border: 2px dashed var(--color-grey-light);
    border-radius: var(--radius-md);
  }
  .placeholder p {
    margin: var(--space-4) auto var(--space-8);
    color: var(--text-secondary);
  }
</style>
